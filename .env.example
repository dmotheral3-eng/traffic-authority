# PostHog — frontend project keys are designed to be public (project tokens).
# Set ONE of these in Vercel project settings to enable analytics.
# If both are unset, the JSX silently no-ops (the site works fine without PostHog).

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Next.js-style names also accepted by the JSX env loader (fallback).
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
